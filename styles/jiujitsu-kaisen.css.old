.jiujitsu-kaisen.sheet.actor {
  font-family: Arial, sans-serif;
}

.jk-header {
  display: flex;
  gap: 12px;
  margin-bottom: 10px;
}

.jk-profile-img {
  width: 130px;
  height: 130px;
  object-fit: cover;
  border: 1px solid #555;
}

.jk-header-info {
  flex: 1;
}

.jk-header-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}

.sheet-tabs {
  margin: 10px 0;
  border-top: 1px solid #777;
  border-bottom: 1px solid #777;
}

.sheet-tabs .item {
  padding: 6px 12px;
}

.jk-main-layout {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 12px;
}

.jk-card {
  border: 1px solid #777;
  border-radius: 6px;
  padding: 10px;
  margin-bottom: 10px;
}

.jk-card h2 {
  margin-top: 0;
  border-bottom: 1px solid #777;
}

.jk-attributes-grid,
.jk-resources-grid,
.jk-combat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

.jiujitsu-kaisen label {
  font-weight: bold;
}

.jiujitsu-kaisen input,
.jiujitsu-kaisen textarea {
  width: 100%;
  box-sizing: border-box;
}

.jiujitsu-kaisen textarea {
  min-height: 120px;
  resize: vertical;
}
.jk-attribute-box {
  border: 1px solid #777;
  border-radius: 6px;
  text-align: center;
  padding: 6px;
}

.jk-attribute-label {
  font-weight: bold;
  border-bottom: 1px solid #777;
  margin-bottom: 4px;
}

.jk-attribute-box input {
  text-align: center;
  font-size: 18px;
  font-weight: bold;
  border: none;
  background: transparent;
}

.jk-attribute-mod {
  margin-top: 4px;
  font-size: 16px;
  font-weight: bold;
  border-top: 1px solid #777;
  padding-top: 4px;
}

.jk-top-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.jk-split-left {
  padding-right: 12px;
  border-right: 1px solid #777;
}

.jk-split-right {
  padding-left: 4px;
}

.jk-split-right label {
  display: grid;
  grid-template-columns: 1fr 70px;
  align-items: center;
  gap: 6px;
  margin-bottom: 4px;
}

.jk-split-right input {
  text-align: center;
}

/* Centralizar títulos dos cards */

.jk-card h2 {
  text-align: center;
}


/* Testes de Resistência */

.jk-resistencia-header {
  display: grid;
  grid-template-columns: 1fr 30px 30px 50px 60px;
  gap: 4px;
  font-weight: bold;
  text-align: center;
  margin-bottom: 6px;
}

.jk-resistencia-row {
  display: grid;
  grid-template-columns: 1fr 30px 30px 50px 60px;
  gap: 4px;
  align-items: center;
  margin-bottom: 4px;
}

.jk-resistencia-row span {
  font-weight: bold;
}

.jk-resistencia-row input[type="checkbox"] {
  margin: auto;
}

.jk-resistencia-row input[type="number"] {
  text-align: center;
}

/* Recursos */

.jk-resource-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.jk-resource-box {
  border: 1px solid #777;
  border-radius: 6px;
  padding: 8px;
}

.jk-resource-box h3 {
  text-align: center;
  margin: 0 0 8px 0;
  border-bottom: 1px solid #777;
  padding-bottom: 4px;
}

.jk-resource-main {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px;
  margin-bottom: 6px;
}

.jk-resource-main label,
.jk-resource-temp,
.jk-resource-box label {
  display: flex;
  flex-direction: column;
  text-align: center;
}

.jk-resource-main input,
.jk-resource-temp input,
.jk-resource-box select {
  text-align: center;
}

/* COMBATE */

.jk-combat-summary {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}

.jk-combat-box {
  border: 1px solid #777;
  border-radius: 6px;
  padding: 8px;
  text-align: center;
}

.jk-combat-box h3 {
  margin: 0;
  padding-bottom: 4px;
  border-bottom: 1px solid #777;
}

.jk-combat-total {
  font-size: 28px;
  font-weight: bold;
  margin: 10px 0;
}

.jk-combat-fields {
  display: flex;
  justify-content: center;
  gap: 6px;
}

.jk-combat-fields label {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 11px;
}

.jk-combat-fields input {
  width: 45px;
  text-align: center;
}

/* Layout principal com coluna fixa para perícias */

.jk-main-layout {
  display: grid;
  grid-template-columns: minmax(0, 2fr) 320px;
  gap: 12px;
  align-items: start;
}

.jk-left-column {
  min-width: 0;
}

.jk-right-column {
  min-width: 300px;
}


/* Recursos mais compactos */

.jk-resource-cards {
  grid-template-columns: repeat(3, 1fr);
  gap: 6px;
}

.jk-resource-box {
  padding: 6px;
}

.jk-resource-box h3 {
  font-size: 15px;
  margin-bottom: 4px;
  padding-bottom: 3px;
}

.jk-resource-main {
  gap: 4px;
  margin-bottom: 4px;
}

.jk-resource-main input,
.jk-resource-temp input,
.jk-resource-box select {
  height: 24px;
  font-size: 13px;
}

.jk-resource-main label,
.jk-resource-temp,
.jk-resource-box label {
  font-size: 12px;
}

/* Compactação da aba principal */

.jk-profile-img {
  width: 100px;
  height: 100px;
}

.jk-top-split {
  gap: 8px;
}

.jk-card {
  padding: 6px;
  margin-bottom: 8px;
}

.jk-card h2 {
  font-size: 18px;
  margin-bottom: 6px;
}

.jk-attributes-grid {
  gap: 6px;
}

.jk-attribute-box {
  padding: 4px;
}

.jk-attribute-box input {
  font-size: 16px;
  font-weight: normal;
}

.jk-attribute-mod {
  font-size: 14px;
}

.jk-resource-main input,
.jk-resource-temp input,
.jk-resource-box select {
  font-weight: normal;
}

.jk-resource-box input {
  font-weight: normal;
}

.jk-resistencia-row {
  margin-bottom: 3px;
}

.jk-resistencia-row span {
  font-weight: normal;
}

/* Perícias */

.jk-skills-card {
  max-height: 560px;
  overflow-y: auto;
}

.jk-skill-header,
.jk-skill-row {
  display: grid;
  grid-template-columns: 1fr 24px 24px 42px 50px;
  gap: 4px;
  align-items: center;
}

.jk-skill-header {
  font-weight: bold;
  text-align: center;
  border-bottom: 1px solid #777;
  margin-bottom: 4px;
  padding-bottom: 4px;
}

.jk-skill-row {
  margin-bottom: 3px;
}

.jk-skill-name {
  font-size: 12px;
}

.jk-skill-row input[type="checkbox"] {
  margin: auto;
}

.jk-skill-row input[type="number"] {
  height: 22px;
  text-align: center;
  font-size: 12px;
}

/* Forçar perícias na lateral direita */

.jk-main-layout {
  display: grid !important;
  grid-template-columns: 660px 300px !important;
  gap: 10px;
  align-items: start;
}

.jk-left-column {
  width: 660px;
  max-width: 660px;
}

.jk-right-column {
  width: 300px;
  max-width: 300px;
}

.jk-skills-card {
  max-height: 560px;
  overflow-y: auto;
}

.jk-skill-header,
.jk-skill-row {
  grid-template-columns: 1fr 20px 20px 36px 40px;
}

.jk-skill-name {
  font-size: 11px;
}

.jk-skill-row input[type="number"] {
  width: 36px;
  height: 20px;
}

.jk-skill-row input[type="checkbox"] {
  width: 14px;
  height: 14px;
}

/* Forçar layout lateral com flex */

.tab.principal .jk-main-layout {
  display: flex !important;
  flex-direction: row !important;
  align-items: flex-start !important;
  gap: 10px !important;
  width: 100% !important;
}

.tab.principal .jk-left-column {
  flex: 0 0 650px !important;
  width: 650px !important;
  max-width: 650px !important;
}

.tab.principal .jk-right-column {
  flex: 0 0 300px !important;
  width: 300px !important;
  max-width: 300px !important;
}

.tab.principal .jk-right-column .jk-card {
  width: 100% !important;
}

/* Correção forte da aba Principal */

.jiujitsu-kaisen .tab[data-tab="principal"] .jk-main-layout {
  display: flex !important;
  flex-direction: row !important;
  flex-wrap: nowrap !important;
  align-items: flex-start !important;
  gap: 10px !important;
}

.jiujitsu-kaisen .tab[data-tab="principal"] .jk-left-column {
  flex: 0 0 650px !important;
  width: 650px !important;
  max-width: 650px !important;
}

.jiujitsu-kaisen .tab[data-tab="principal"] .jk-right-column {
  flex: 0 0 300px !important;
  width: 300px !important;
  max-width: 300px !important;
}

/* Harmonização visual da aba Principal */

.jk-card {
  border-radius: 5px;
}

.jk-card h2 {
  font-size: 17px;
  font-weight: 600;
}

.jk-attribute-box,
.jk-resource-box,
.jk-combat-box,
.jk-skills-card {
  border-radius: 5px;
}

.jk-combat-summary {
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}

.jk-combat-box {
  min-height: 118px;
  padding: 6px;
}

.jk-combat-box h3 {
  font-size: 16px;
  font-weight: 600;
}

.jk-combat-total {
  font-size: 24px;
  font-weight: normal;
  margin: 8px 0;
}

.jk-combat-fields label {
  font-size: 11px;
  font-weight: 600;
}

.jk-combat-fields input {
  height: 22px;
  font-size: 12px;
  font-weight: normal;
}

.jk-attribute-box input,
.jk-attribute-mod,
.jk-resource-box input,
.jk-resource-box select,
.jk-skill-row input {
  font-weight: normal;
}

.jk-skills-card h2 {
  font-size: 17px;
}

/* ------------------------- */
/* Ajustes finais da Principal */
/* ------------------------- */

/* Cabeçalho das perícias */
.jk-skill-header span:first-child {
  text-align: left;
  padding-left: 4px;
}

/* Nome das perícias */
.jk-skill-name {
  font-size: 13px;
  font-weight: 500;
}

/* Testes de resistência */
.jk-resistencia-row span:first-child {
  text-transform: capitalize;
  font-size: 13px;
}

/* Unidade metros */
.jk-unit {
  font-size: 18px;
  font-weight: normal;
  opacity: .85;
  margin-left: 6px;
}

/* Salvaguarda de Morte */
.jk-death-save {
  margin-top: 12px;
  padding-top: 8px;
  border-top: 1px solid #777;
}

.jk-death-save-title {
  text-align: center;
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 10px;
}

.jk-death-save-track {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.jk-death-side {
  display: flex;
  align-items: center;
  gap: 4px;
}

.jk-death-side span {
  font-size: 11px;
}

.jk-death-center {
  font-size: 18px;
  opacity: .8;
}

/* Checkboxes menores */
.jk-death-save input[type="checkbox"] {
  width: 14px;
  height: 14px;
}

/* Salvaguarda de Morte ocupando Atributos + Resistência */

.jk-death-save-wide {
  grid-column: 1 / -1;
  margin-top: 8px;
  padding-top: 6px;
  border-top: 1px solid #777;
}

.jk-death-save-wide .jk-death-save-title {
  text-align: center;
  font-weight: 600;
  margin-bottom: 4px;
}

.jk-death-save-columns {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  margin-top: 10px;
}

.jk-death-save-wide .jk-death-side {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  font-size: 15px;
  font-weight: 600;
}

.jk-death-side-right {
  justify-content: center;
}

.jk-death-save-wide input[type="checkbox"] {
  width: 18px;
  height: 18px;
}

.jk-death-side span {
  font-size: 16px;
  font-weight: 600;
}

/* Ajuste final da coluna de Perícias */

.jiujitsu-kaisen .jk-right-column {
  align-self: start;
}

.jiujitsu-kaisen .jk-skills-card {
  height: auto;
  min-height: 0;
  max-height: none;
  overflow-y: visible;
}

.jiujitsu-kaisen .jk-skill-row {
  min-height: 22px;
}
