/* ============================= */
/* Aba Principal                 */
/* ============================= */

/* Estrutura superior */

.jk-top-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;

  padding: 12px;

  background: #1E1B26;
}

.jk-split-left,
.jk-split-right {
  background: #252231;

  border: 1px solid #3A3548;
  border-radius: 6px;

  padding: 14px;

  box-shadow: 0 2px 8px rgba(0,0,0,0.35);
}

.jk-split-left {
  border-right: 1px solid #3A3548;
}

.jk-split-right {
  padding-left: 14px;
}

/* Cabeçalhos editoriais */

.jk-card h2 {
  display: flex;
  align-items: center;
  gap: 10px;

  margin: 0 0 12px;
  padding: 0;

  background: transparent;
  border: none;

  font-family: "Cinzel", serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.09em;

  color: #d4b8e8;

  text-align: center;
  text-transform: none;
}

.jk-card h2::before,
.jk-card h2::after {
  content: "";
  flex: 1;

  height: 1px;

  background: #3A3548;
}

/* ============================= */
/* Atributos                     */
/* ============================= */

.jk-attributes-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

.jk-attribute-box {
  background: transparent;

  border: none;
  border-bottom: 1px solid #3A3548;

  text-align: center;

  padding: 6px 4px 10px;
}

.jk-attribute-label {
  display: block;

  margin: 0 0 4px;
  padding: 0;

  border: none;

  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.08em;

  color: #6b6080;

  text-transform: uppercase;
}

.jk-attribute-box input[type="number"] {
  width: 100%;

  padding: 0;

  background: transparent;
  color: #f0e0ff;

  border: none;

  font-family: "Courier New", monospace;
  font-size: 28px;
  font-weight: 700;
  line-height: 1;

  text-align: center;
}

.jk-attribute-box input[type="number"]:focus {
  outline: none;
  box-shadow: none;
}

.jk-attribute-mod {
  display: block;

  margin-top: 4px;
  padding: 0;

  border: none;

  font-size: 12px;
  font-weight: 600;

  color: #9b7fd4;
}

/* ============================= */
/* Testes de Resistência         */
/* ============================= */

.jk-resistencia-header,
.jk-resistencia-row {
  display: grid;
  grid-template-columns: 1fr 30px 30px 50px 44px;
  gap: 6px;
  align-items: center;
}

.jk-resistencia-header {
  margin-bottom: 8px;

  font-size: 11px;
  font-weight: 700;

  color: #d4b8e8;

  text-align: center;
}

.jk-resistencia-row {
  padding: 5px 0;

  border-bottom: 1px solid #3A3548;
}

.jk-resistencia-row:last-child {
  border-bottom: none;
}

.jk-resistencia-row span:first-child {
  font-size: 12px;
  font-weight: 500;

  color: #9b7fd4;

  text-transform: capitalize;
}

.jk-resistencia-row input[type="checkbox"] {
  width: 14px;
  height: 14px;

  margin: auto;

  accent-color: #9b7fd4;

  cursor: pointer;
}

.jk-resistencia-row input[type="number"] {
  width: 100%;
  height: 22px;

  padding: 2px 4px;

  background: transparent;
  color: #f0e0ff;

  border: none;
  border-bottom: 1px solid #3A3548;
  border-radius: 0;

  font-family: "Courier New", monospace;
  font-size: 12px;
  font-weight: 700;

  text-align: center;
}

.jk-resistencia-row input[type="number"]:focus {
  outline: none;
  border-bottom-color: #5c1f2e;
  box-shadow: none;
}

.jk-resistencia-total {
  min-width: 28px;

  justify-self: end;

  font-size: 13px;
  font-weight: 700;

  color: #9b7fd4;

  text-align: right;
}

/* ============================= */
/* Salvaguarda de Morte          */
/* ============================= */

.jk-death-save-wide {
  grid-column: 1 / -1;

  margin-top: 12px;

  background: #252231;

  border: 1px solid #3A3548;
  border-radius: 6px;

  overflow: hidden;
}

.jk-death-drawer {
  cursor: pointer;
  user-select: none;
}

.jk-death-drawer-summary {
  display: grid;
  grid-template-columns: 1fr auto auto 1fr;
  align-items: center;
  gap: 8px;

  padding: 8px 12px;

  background: #2C2838;

  border-bottom: 1px solid #3A3548;

  list-style: none;
}

.jk-death-drawer-summary::-webkit-details-marker {
  display: none;
}

.jk-death-drawer-line {
  height: 1px;

  background: #3A3548;
}

.jk-death-drawer-icon {
  color: #5c1f2e;

  font-size: 14px;
}

.jk-death-drawer-arrow {
  color: #3f3a52;

  font-size: 11px;

  transition: transform 0.2s;
}

.jk-death-drawer[open] .jk-death-drawer-arrow {
  transform: rotate(180deg);
}

.jk-death-drawer-content {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 10px;

  padding: 12px;

  background: #252231;
}

.jk-death-side {
  display: flex;
  align-items: center;
  gap: 6px;
}

.jk-death-side-success {
  justify-content: flex-end;
}

.jk-death-side-failure {
  justify-content: flex-start;
}

.jk-death-side span {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.06em;

  color: #6b6080;

  text-transform: uppercase;
}

.jk-death-center {
  width: 28px;
  height: 28px;

  padding: 0;

  display: flex;
  align-items: center;
  justify-content: center;

  background: #2C2838;
  color: #6b6080;

  border: 1px solid #3A3548;
  border-radius: 3px;

  font-size: 12px;

  cursor: pointer;
}

.jk-death-center:hover {
  background: #332F42;
  color: #9b7fd4;

  border-color: #4A4460;
}

.jk-death-center:focus,
.jk-death-center:focus-visible {
  outline: none;
  box-shadow: none;
}

.jk-death-box {
  width: 18px;
  height: 18px;

  padding: 0;
  margin: 0;

  background: #1E1B26;

  border: 1px solid #3A3548;
  border-radius: 3px;

  cursor: pointer;

  transition:
    background 0.15s,
    border-color 0.15s;
}

.jk-death-box:hover {
  background: #332F42;
  border-color: #4A4460;
}

.jk-death-box:focus,
.jk-death-box:focus-visible,
.jk-death-box:active {
  outline: none;
  box-shadow: none;
}

.jk-death-success.active {
  background: #9b7fd4;
  border-color: #9b7fd4;
}

.jk-death-failure.active {
  background: #8b1a2e;
  border-color: #8b1a2e;
}

/* ============================= */
/* Informações                   */
/* ============================= */

.jk-info-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;

  padding: 12px;

  background: #1E1B26;
}

/* Cards de Informações */

.jk-combat-box {
  background: #252231;

  border: 1px solid #3A3548;
  border-top: 2px solid #5c1f2e;
  border-radius: 4px;

  padding: 10px 8px 8px;

  text-align: center;

  box-shadow: 0 2px 8px rgba(0,0,0,0.35);
}

.jk-combat-box h3 {
  margin: 0 0 6px;
  padding: 0 0 6px;

  background: transparent;

  border: none;
  border-bottom: 1px solid #3A3548;

  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.07em;

  color: #6b6080;

  text-transform: uppercase;
}

.jk-combat-total {
  display: block;

  margin: 4px 0;

  font-family: "Courier New", monospace;
  font-size: 26px;
  font-weight: 700;
  line-height: 1;

  color: #f0e0ff;
}

.jk-unit {
  margin-left: 4px;

  font-size: 10px;
  letter-spacing: 0.05em;

  color: #6b6080;

  text-transform: uppercase;
}

.jk-combat-fields {
  display: flex;
  justify-content: center;
  gap: 8px;

  margin-top: 6px;
  padding-top: 6px;

  border-top: 1px solid #3A3548;
}

.jk-combat-fields label {
  display: flex;
  flex-direction: column;
  align-items: center;

  font-size: 9px;
  font-weight: 600;

  color: #6b6080;
}

.jk-combat-fields input {
  width: 42px;
  height: 22px;

  padding: 2px 4px;

  background: transparent;
  color: #f0e0ff;

  border: none;
  border-bottom: 1px solid #3A3548;
  border-radius: 0;

  font-family: "Courier New", monospace;
  font-size: 12px;
  font-weight: 700;

  text-align: center;
}

.jk-combat-fields input:focus {
  outline: none;
  border-bottom-color: #5c1f2e;
  box-shadow: none;
}

/* Defesa */

.jk-defense-title {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;

  margin-bottom: 6px;
}

.jk-defense-attribute-wrapper {
  position: relative;

  display: inline-block;
}

.jk-defense-attribute {
  padding: 2px 6px;

  background: #2C2838;
  color: #6b6080;

  border: 1px solid #3A3548;
  border-radius: 3px;

  font-size: 9px;
  font-weight: 700;

  text-align: center;
  text-align-last: center;
}

.jk-defense-fields {
  display: flex;
  justify-content: center;
  gap: 6px;
  flex-wrap: wrap;

  margin-top: 4px;
}

.jk-defense-fields input {
  width: 36px;
}

/* ============================= */
/* Recursos                      */
/* ============================= */

.jk-resource-box {
  background: #252231;

  border: 1px solid #3A3548;
  border-left: 3px solid #8b1a2e;
  border-radius: 0 4px 4px 0;

  padding: 10px 12px;

  text-align: center;
}

.jk-resource-box h3 {
  margin: 0 0 8px;
  padding: 0 0 5px;

  background: transparent;

  border: none;
  border-bottom: 1px solid #3A3548;

  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.07em;

  color: #6b6080;

  text-transform: uppercase;
}

.jk-resource-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 6px;
}

.jk-resource-main label,
.jk-resource-temp,
.jk-resource-box label {
  display: flex;
  flex-direction: column;
  align-items: center;

  font-size: 9px;
  font-weight: 600;

  color: #6b6080;
}

.jk-resource-main input,
.jk-resource-main .value {
  width: 52px;

  background: transparent;
  color: #f0e0ff;

  border: none;
  border-bottom: 1px solid #3A3548;
  border-radius: 0;

  font-family: "Courier New", monospace;
  font-size: 22px;
  font-weight: 700;

  text-align: center;
}

.jk-resource-main input:focus {
  outline: none;
  border-bottom-color: #5c1f2e;
  box-shadow: none;
}

.jk-resource-temp {
  margin-top: 6px;
  padding-top: 6px;

  border-top: 1px solid #3A3548;
}

.jk-resource-temp input,
.jk-resource-box input,
.jk-resource-box select {
  width: 100%;

  padding: 2px 4px;

  background: transparent;
  color: #f0e0ff;

  border: none;
  border-bottom: 1px solid #3A3548;
  border-radius: 0;

  font-family: "Courier New", monospace;
  font-size: 12px;
  font-weight: 700;

  text-align: center;
}

.jk-resource-temp input:focus,
.jk-resource-box input:focus,
.jk-resource-box select:focus {
  outline: none;
  border-bottom-color: #5c1f2e;
  box-shadow: none;
}

.jk-resource-box input[readonly] {
  color: #9b7fd4;

  background: transparent;

  border-bottom-color: #3A3548;
}

/* ============================= */
/* Correções visuais - Principal */
/* ============================= */

/* 1. Cards: acento carmesim apenas no topo */

.jk-combat-box,
.jk-resource-box {
  border: 1px solid #3A3548;
  border-top: 2px solid #5c1f2e;
  border-left: 1px solid #3A3548;
  border-radius: 4px;
}

/* 2. Linhas decorativas harmônicas */

.jk-card h2::before,
.jk-card h2::after,
.jk-resistencia-header::before,
.jk-resistencia-header::after {
  background: #3A3548;
}

/* 3. Checkboxes no padrão da ficha */

.jiujitsu-kaisen input[type="checkbox"] {
  appearance: none;
  -webkit-appearance: none;

  width: 14px;
  height: 14px;

  background: #2C2838;

  border: 1px solid #4A4460;
  border-radius: 2px;

  cursor: pointer;
}

.jiujitsu-kaisen input[type="checkbox"]:checked {
  background: #9b7fd4;
  border-color: #9b7fd4;
}

.jiujitsu-kaisen input[type="checkbox"]:focus,
.jiujitsu-kaisen input[type="checkbox"]:focus-visible {
  outline: none;
  box-shadow: none;
}

/* 4. Atributos com presença sutil */

.jk-attribute-box {
  background: #252231;

  border: 1px solid #3A3548;
  border-radius: 4px;

  padding: 8px 4px 10px;
}

/* 5. Gaveta da Salvaguarda: caveira centralizada */

.jk-death-drawer-summary {
  display: flex;
  align-items: center;
  justify-content: center;

  gap: 8px;
}

.jk-death-drawer-line {
  flex: 1;
}

.jk-death-drawer-icon {
  display: flex;
  align-items: center;
  justify-content: center;

  color: #6b6080;

  font-size: 16px;

  text-align: center;
}

.jk-death-drawer-arrow {
  flex: 0 0 auto;
}
