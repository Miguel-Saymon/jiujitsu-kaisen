/* ============================= */
/* Header do Personagem          */
/* ============================= */

.jk-header {
  display: flex;
  gap: 14px;
  align-items: stretch;

  margin-bottom: 12px;
  padding: 16px 20px;

  background: #1E1228;
  border-bottom: 2px solid #4A1020;
}

.jk-profile-img {
  width: 130px;
  min-width: 130px;
  height: auto;

  object-fit: cover;

  background: #2B2134;

  border: 1px solid #3A3548;
  border-radius: 3px;
}

.jk-header-info {
  flex: 1;
  min-width: 0;
}

.jk-header-info h1 {
  width: 100%;

  text-align: center;
  display: block;

  margin: 0 0 12px 0;
  padding-bottom: 4px;

  border-bottom: 2px solid #4A1020;

  font-family: "Cinzel", serif;
  font-size: 22px;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: 0.04em;

  color: #f0e0ff;

  text-transform: none;
  background: #1E1228;
}

/* Grid */

.jk-header-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 8px;
  align-items: end;
}

/* Labels */

.jk-header-grid label {
  display: block;

  margin-bottom: 3px;

  font-size: 9px;
  font-weight: 700;

  letter-spacing: 0.07em;
  text-transform: uppercase;

  color: #6b4a8a;
}

/* Todos os campos iguais */

.jiujitsu-kaisen .jk-header .jk-header-grid input,
.jiujitsu-kaisen .jk-header .jk-header-grid select {
  width: 100%;
  min-height: 26px;

  padding: 4px 8px;

  background: #2B2134;
  color: #f0e0ff;

  border: 1px solid #3A3548;
  border-radius: 3px;

  font-family: system-ui, sans-serif;
  font-size: 12px;
  font-weight: 500;
  line-height: 1.5;
}

.jiujitsu-kaisen .jk-header .jk-header-grid input:hover,
.jiujitsu-kaisen .jk-header .jk-header-grid select:hover {
  background: #332A3E;
  border-color: #4A4460;
}

.jiujitsu-kaisen .jk-header .jk-header-grid input:focus,
.jiujitsu-kaisen .jk-header .jk-header-grid select:focus {
  outline: none;
  background: #332A3E;
  border-color: #9b7fd4;
  box-shadow: none;
}

.jiujitsu-kaisen .jk-header .jk-header-grid select option {
  background: #2B2134;
  color: #f0e0ff;
}

/* Dropdown */

.jk-header-grid select,
.jk-header-grid select option {
  background: #2B2134;
  color: #f0e0ff;
}

/* Campos específicos */

.jk-header-field {
  grid-column: span 3;
}

.jk-field-grau {
  grid-column: 2 / span 3;
}

.jk-field-nivel {
  grid-column: 5 / span 3;
}

.jk-field-experiencia {
  grid-column: 8 / span 3;
}

.jk-field-grau select {
  text-align: center;
  text-align-last: center;
}

/* Controles internos */

.jk-level-control,
.jk-specialization-control {
  position: relative;
  width: 100%;
}

.jk-level-control input,
.jk-specialization-control input {
  width: 100%;
  padding-right: 24px;
}

/* Remove diferenciação visual de nível/especialização */

.jk-level-control input,
.jk-specialization-control input,
.jk-field-nivel input,
.jk-field-especializacao input {
  background: #2B2134;
  color: #f0e0ff;

  border: 1px solid #3A3548;
  border-radius: 3px;

  font-family: system-ui, sans-serif;
  font-weight: 500;
  text-align: left;
}

/* Botões pequenos */

.jk-add-level,
.jk-reset-progression {
  position: absolute;

  right: 2px;
  top: 50%;

  transform: translateY(-50%);

  width: 18px;
  height: 18px;

  padding: 0;

  display: flex;
  align-items: center;
  justify-content: center;

  background: transparent;
  color: #d4b8e8;

  border: none;
  border-radius: 0;

  font-size: 12px;
  font-weight: 700;
  line-height: 1;

  cursor: pointer;
}

.jk-add-level:hover,
.jk-reset-progression:hover {
  color: #f0e0ff;
}

.jk-add-level:focus,
.jk-reset-progression:focus {
  outline: none;
  box-shadow: none;
}

/* Nome do personagem — input interno */

.jiujitsu-kaisen .jk-header .jk-header-info h1 {
  width: 100%;
  margin: 0 0 12px 0;
  padding: 0;

  background: transparent;
  border: none;
}

.jiujitsu-kaisen .jk-header .jk-header-info h1 input,
.jiujitsu-kaisen .jk-header .jk-header-info h1 input[name="name"] {
  width: 100%;

  padding: 6px 12px 8px;

  background: #33283D;
  color: #f0e0ff;

  border: 1px solid #3A3548;
  border-bottom: 2px solid #4A1020;
  border-radius: 3px;

  font-family: "Cinzel", serif;
  font-size: 22px;
  font-weight: 700;
  letter-spacing: 0.04em;

  text-align: center;
  text-transform: none;
}

.jiujitsu-kaisen .jk-header .jk-header-info h1 input:focus {
  outline: none;
  box-shadow: none;
  background: #33283D;
  border-color: #3A3548;
  border-bottom-color: #4A1020;
}

/* Correção final: campo do nome do personagem */

.jiujitsu-kaisen.sheet.actor .jk-header .jk-header-info h1 {
  width: 100%;
  margin: 0 0 12px;
  padding: 0;

  background: transparent !important;
  border: none !important;
}

.jiujitsu-kaisen.sheet.actor .jk-header .jk-header-info h1 input,
.jiujitsu-kaisen.sheet.actor .jk-header .jk-header-info h1 input[name="name"] {
  width: 100%;

  padding: 6px 12px 8px;

  background: #2B2134 !important;
  color: #f0e0ff !important;

  border: 1px solid #3A3548 !important;
  border-bottom: 2px solid #4A1020 !important;
  border-radius: 3px !important;

  font-family: "Cinzel", serif !important;
  font-size: 22px !important;
  font-weight: 700 !important;
  letter-spacing: 0.04em;

  text-align: center !important;
  text-transform: none !important;
}

.jiujitsu-kaisen.sheet.actor .jk-header .jk-header-info h1 input:hover,
.jiujitsu-kaisen.sheet.actor .jk-header .jk-header-info h1 input:focus {
  background: #2B2134 !important;
  color: #f0e0ff !important;

  outline: none !important;
  box-shadow: none !important;

  border-color: #3A3548 !important;
  border-bottom-color: #4A1020 !important;
}

/* Correção definitiva: campo do nome do personagem */

.jiujitsu-kaisen.sheet.actor .jk-header .jk-header-info h1 {
  width: 100%;
  margin: 0 0 12px;
  padding: 0;
  border: none;
  background: transparent;
}

.jiujitsu-kaisen.sheet.actor .jk-header .jk-header-info h1 > input[name="name"] {
  width: 100%;

  padding: 6px 12px;

  background: #21182B;
  color: #f0e0ff;

  border: 1px solid #3A3548;
  border-bottom: 2px solid #4A1020;
  border-radius: 3px;

  font-family: "Cinzel", serif;
  font-size: 22px;
  font-weight: 700;
  letter-spacing: 0.04em;

  text-align: center;
  text-transform: none;

  box-shadow: none;
}

.jiujitsu-kaisen.sheet.actor .jk-header .jk-header-info h1 > input[name="name"]:hover,
.jiujitsu-kaisen.sheet.actor .jk-header .jk-header-info h1 > input[name="name"]:focus {
  background: #21182B;
  color: #f0e0ff;

  border-color: #3A3548;
  border-bottom-color: #4A1020;

  outline: none;
  box-shadow: none;
}
