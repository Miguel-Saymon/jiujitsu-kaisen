<div class="tab" data-group="primary" data-tab="combate">

    <div class="jk-combate-layout">

        {{!-- LINHA SUPERIOR --}}
        <div class="jk-combate-top-row">

            <section class="jk-card jk-combate-card">
                <h2>Características</h2>

                <textarea
                    class="jk-free-field"
                    name="system.combate.caracteristicas"
                    placeholder="campo livre..."
                >{{system.combate.caracteristicas}}</textarea>
            </section>

            <section class="jk-card jk-combate-card">
                <header class="jk-combat-section-header">
                    <h2>Habilidades &amp; Talentos</h2>
                    <button
                        class="jk-add-combat-row"
                        type="button"
                        data-path="combate.habilidades"
                        data-prefix="habilidade"
                        title="Adicionar habilidade ou talento"
                    >+</button>
                </header>

                <table class="jk-talent-table">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Atual</th>
                            <th>Máx.</th>
                            <th>Custo</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>
                        {{#each combateHabilidades as |habilidade|}}
                        <tr>
                            <td>
                                <input
                                    name="system.combate.habilidades.{{habilidade.key}}.nome"
                                    type="text"
                                    value="{{habilidade.nome}}"
                                    placeholder="+ nova habilidade"
                                />
                            </td>
                            <td class="is-val">
                                <input
                                    name="system.combate.habilidades.{{habilidade.key}}.atual"
                                    type="number"
                                    value="{{habilidade.atual}}"
                                />
                            </td>
                            <td class="is-val">
                                <input
                                    name="system.combate.habilidades.{{habilidade.key}}.max"
                                    type="number"
                                    value="{{habilidade.max}}"
                                />
                            </td>
                            <td class="is-cost">
                                <input
                                    name="system.combate.habilidades.{{habilidade.key}}.custo"
                                    type="text"
                                    value="{{habilidade.custo}}"
                                />
                            </td>
                            <td class="is-action">
                                <button
                                    class="jk-remove-combat-row"
                                    type="button"
                                    data-path="combate.habilidades"
                                    data-key="{{habilidade.key}}"
                                    title="Remover habilidade ou talento"
                                >×</button>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </section>

        </div>

        {{!-- LINHA PRINCIPAL --}}
        <div class="jk-combate-mid-row">

            <div class="jk-combate-mid-left">

                <section class="jk-combate-cd-row">

                    <div class="jk-combat-box jk-combate-cd-box">
                        <h3>CD Especialização</h3>

                        <div class="jk-combat-total">
                            {{system.combate.cd.total}}
                        </div>

                        <div class="jk-cd-breakdown">
                            <span>Base {{system.combate.cd.base}}</span>
                            <span>Atr. {{system.combate.cd.atributoBonus}}</span>
                            <span>Treino {{system.combate.cd.treino}}</span>
                            <span>Nível {{system.combate.cd.nivel}}</span>
                        </div>

                        <div class="jk-combat-fields">
                            <label>
                                Atr.
                                <select name="system.combate.cd.atributo">
                                    <option value="forca" {{#if (eq system.combate.cd.atributo "forca")}}selected{{/if}}>FOR</option>
                                    <option value="destreza" {{#if (eq system.combate.cd.atributo "destreza")}}selected{{/if}}>DES</option>
                                    <option value="constituicao" {{#if (eq system.combate.cd.atributo "constituicao")}}selected{{/if}}>CON</option>
                                    <option value="inteligencia" {{#if (eq system.combate.cd.atributo "inteligencia")}}selected{{/if}}>INT</option>
                                    <option value="sabedoria" {{#if (eq system.combate.cd.atributo "sabedoria")}}selected{{/if}}>SAB</option>
                                    <option value="presenca" {{#if (eq system.combate.cd.atributo "presenca")}}selected{{/if}}>PRE</option>
                                </select>
                            </label>

                            <label>
                                Outros
                                <input
                                    name="system.combate.cd.outros"
                                    type="number"
                                    value="{{system.combate.cd.outros}}"
                                />
                            </label>
                        </div>
                    </div>

                    <div class="jk-combat-box jk-combate-desloc-box">
                        <h3>Deslocamento</h3>

                        <div class="jk-combat-total">
                            {{system.combate.deslocamento}}
                            <span class="jk-unit">m</span>
                        </div>

                        <div class="jk-combat-fields">
                            <label>
                                Metros
                                <input
                                    name="system.combate.deslocamento"
                                    type="number"
                                    value="{{system.combate.deslocamento}}"
                                />
                            </label>
                        </div>
                    </div>

                </section>

                <section class="jk-card jk-combate-card">
                    <h2>RDs</h2>

                    <div class="jk-rd-grid">
<label class="jk-rd-box rd-cor"><span class="jk-rd-box__label">COR</span><input class="jk-rd-box__input" name="system.combate.rd.cor" type="number" value="{{system.combate.rd.cor}}" /></label>
<label class="jk-rd-box rd-imp"><span class="jk-rd-box__label">IMP</span><input class="jk-rd-box__input" name="system.combate.rd.imp" type="number" value="{{system.combate.rd.imp}}" /></label>
<label class="jk-rd-box rd-per"><span class="jk-rd-box__label">PER</span><input class="jk-rd-box__input" name="system.combate.rd.per" type="number" value="{{system.combate.rd.per}}" /></label>
<label class="jk-rd-box rd-con"><span class="jk-rd-box__label">CON</span><input class="jk-rd-box__input" name="system.combate.rd.con" type="number" value="{{system.combate.rd.con}}" /></label>
<label class="jk-rd-box rd-que"><span class="jk-rd-box__label">QUE</span><input class="jk-rd-box__input" name="system.combate.rd.que" type="number" value="{{system.combate.rd.que}}" /></label>
<label class="jk-rd-box rd-cho"><span class="jk-rd-box__label">CHO</span><input class="jk-rd-box__input" name="system.combate.rd.cho" type="number" value="{{system.combate.rd.cho}}" /></label>

<label class="jk-rd-box rd-son"><span class="jk-rd-box__label">SON</span><input class="jk-rd-box__input" name="system.combate.rd.son" type="number" value="{{system.combate.rd.son}}" /></label>
<label class="jk-rd-box rd-ene"><span class="jk-rd-box__label">ENE</span><input class="jk-rd-box__input" name="system.combate.rd.ene" type="number" value="{{system.combate.rd.ene}}" /></label>
<label class="jk-rd-box rd-psi"><span class="jk-rd-box__label">PSI</span><input class="jk-rd-box__input" name="system.combate.rd.psi" type="number" value="{{system.combate.rd.psi}}" /></label>
<label class="jk-rd-box rd-rad"><span class="jk-rd-box__label">RAD</span><input class="jk-rd-box__input" name="system.combate.rd.rad" type="number" value="{{system.combate.rd.rad}}" /></label>
<label class="jk-rd-box rd-nec"><span class="jk-rd-box__label">NEC</span><input class="jk-rd-box__input" name="system.combate.rd.nec" type="number" value="{{system.combate.rd.nec}}" /></label>
<label class="jk-rd-box rd-ven"><span class="jk-rd-box__label">VEN</span><input class="jk-rd-box__input" name="system.combate.rd.ven" type="number" value="{{system.combate.rd.ven}}" /></label>
                    </div>
                </section>

                <section class="jk-card jk-combate-card">
                    <h2>Resistências</h2>

                    <textarea
                        class="jk-free-field"
                        name="system.combate.resistencias"
                        placeholder="campo livre..."
                    >{{system.combate.resistencias}}</textarea>
                </section>

            </div>

            <section class="jk-card jk-combate-card jk-inventory-attack-card">
                <h2>Inventário &amp; Ataques</h2>

                <div class="jk-combat-list-block">
                    <header class="jk-combat-subheader">
                        <h3>Inventário</h3>
                        <button
                            class="jk-add-combat-row"
                            type="button"
                            data-path="combate.inventario"
                            data-prefix="item"
                            title="Adicionar item"
                        >+</button>
                    </header>

                    <table class="jk-combat-list-table jk-inventory-table">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Qtd.</th>
                                <th>Peso</th>
                                <th>Notas</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each combateInventario as |item|}}
                            <tr>
                                <td><input name="system.combate.inventario.{{item.key}}.nome" type="text" value="{{item.nome}}" placeholder="item" /></td>
                                <td class="is-small"><input name="system.combate.inventario.{{item.key}}.quantidade" type="number" value="{{item.quantidade}}" /></td>
                                <td class="is-small"><input name="system.combate.inventario.{{item.key}}.peso" type="text" value="{{item.peso}}" /></td>
                                <td><input name="system.combate.inventario.{{item.key}}.notas" type="text" value="{{item.notas}}" /></td>
                                <td class="is-action"><button class="jk-remove-combat-row" type="button" data-path="combate.inventario" data-key="{{item.key}}" title="Remover item">×</button></td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>

                <div class="jk-combat-list-block">
                    <header class="jk-combat-subheader">
                        <h3>Ataques</h3>
                        <button
                            class="jk-add-combat-row"
                            type="button"
                            data-path="combate.ataques"
                            data-prefix="ataque"
                            title="Adicionar ataque"
                        >+</button>
                    </header>

                    <table class="jk-combat-list-table jk-attack-table">
                        <thead>
                            <tr>
                                <th>Nome</th>
                                <th>Bônus</th>
                                <th>Dano</th>
                                <th>Tipo</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each combateAtaques as |ataque|}}
                            <tr>
                                <td><input name="system.combate.ataques.{{ataque.key}}.nome" type="text" value="{{ataque.nome}}" placeholder="ataque" /></td>
                                <td class="is-small"><input name="system.combate.ataques.{{ataque.key}}.bonus" type="number" value="{{ataque.bonus}}" /></td>
                                <td><input name="system.combate.ataques.{{ataque.key}}.dano" type="text" value="{{ataque.dano}}" placeholder="1d8" /></td>
                                <td class="is-small"><input name="system.combate.ataques.{{ataque.key}}.tipo" type="text" value="{{ataque.tipo}}" placeholder="COR" /></td>
                                <td class="is-action"><button class="jk-remove-combat-row" type="button" data-path="combate.ataques" data-key="{{ataque.key}}" title="Remover ataque">×</button></td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
            </section>

        </div>

    </div>

</div>

