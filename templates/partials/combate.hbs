<div class="tab" data-group="primary" data-tab="combate">

    <div class="jk-combate-layout">

        {{!-- LINHA SUPERIOR --}}
        <div class="jk-combate-top-row">

            <section class="jk-card jk-combate-card">
                <h2>Características</h2>

                <textarea
                    class="jk-free-field"
                    name="system.combate.caracteristicas"
                    placeholder="campo livre..."
                >{{system.combate.caracteristicas}}</textarea>
            </section>

            <section class="jk-card jk-combate-card">
                <h2>Habilidades &amp; Talentos</h2>

                <table class="jk-talent-table">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Atual</th>
                            <th>Máx.</th>
                            <th>Custo</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr>
                            <td>
                                <input
                                    name="system.combate.habilidades.habilidade1.nome"
                                    type="text"
                                    value="{{system.combate.habilidades.habilidade1.nome}}"
                                    placeholder="+ nova habilidade"
                                />
                            </td>
                            <td class="is-val">
                                <input
                                    name="system.combate.habilidades.habilidade1.atual"
                                    type="number"
                                    value="{{system.combate.habilidades.habilidade1.atual}}"
                                />
                            </td>
                            <td class="is-val">
                                <input
                                    name="system.combate.habilidades.habilidade1.max"
                                    type="number"
                                    value="{{system.combate.habilidades.habilidade1.max}}"
                                />
                            </td>
                            <td class="is-cost">
                                <input
                                    name="system.combate.habilidades.habilidade1.custo"
                                    type="text"
                                    value="{{system.combate.habilidades.habilidade1.custo}}"
                                />
                            </td>
                        </tr>

                        <tr>
                            <td>
                                <input
                                    name="system.combate.habilidades.habilidade2.nome"
                                    type="text"
                                    value="{{system.combate.habilidades.habilidade2.nome}}"
                                    placeholder="+ nova habilidade"
                                />
                            </td>
                            <td class="is-val">
                                <input
                                    name="system.combate.habilidades.habilidade2.atual"
                                    type="number"
                                    value="{{system.combate.habilidades.habilidade2.atual}}"
                                />
                            </td>
                            <td class="is-val">
                                <input
                                    name="system.combate.habilidades.habilidade2.max"
                                    type="number"
                                    value="{{system.combate.habilidades.habilidade2.max}}"
                                />
                            </td>
                            <td class="is-cost">
                                <input
                                    name="system.combate.habilidades.habilidade2.custo"
                                    type="text"
                                    value="{{system.combate.habilidades.habilidade2.custo}}"
                                />
                            </td>
                        </tr>

                        <tr>
                            <td>
                                <input
                                    name="system.combate.habilidades.habilidade3.nome"
                                    type="text"
                                    value="{{system.combate.habilidades.habilidade3.nome}}"
                                    placeholder="+ nova habilidade"
                                />
                            </td>
                            <td class="is-val">
                                <input
                                    name="system.combate.habilidades.habilidade3.atual"
                                    type="number"
                                    value="{{system.combate.habilidades.habilidade3.atual}}"
                                />
                            </td>
                            <td class="is-val">
                                <input
                                    name="system.combate.habilidades.habilidade3.max"
                                    type="number"
                                    value="{{system.combate.habilidades.habilidade3.max}}"
                                />
                            </td>
                            <td class="is-cost">
                                <input
                                    name="system.combate.habilidades.habilidade3.custo"
                                    type="text"
                                    value="{{system.combate.habilidades.habilidade3.custo}}"
                                />
                            </td>
                        </tr>

                        <tr>
                            <td>
                                <input
                                    name="system.combate.habilidades.habilidade4.nome"
                                    type="text"
                                    value="{{system.combate.habilidades.habilidade4.nome}}"
                                    placeholder="+ nova habilidade"
                                />
                            </td>
                            <td class="is-val">
                                <input
                                    name="system.combate.habilidades.habilidade4.atual"
                                    type="number"
                                    value="{{system.combate.habilidades.habilidade4.atual}}"
                                />
                            </td>
                            <td class="is-val">
                                <input
                                    name="system.combate.habilidades.habilidade4.max"
                                    type="number"
                                    value="{{system.combate.habilidades.habilidade4.max}}"
                                />
                            </td>
                            <td class="is-cost">
                                <input
                                    name="system.combate.habilidades.habilidade4.custo"
                                    type="text"
                                    value="{{system.combate.habilidades.habilidade4.custo}}"
                                />
                            </td>
                        </tr>

                        <tr>
                            <td>
                                <input
                                    name="system.combate.habilidades.habilidade5.nome"
                                    type="text"
                                    value="{{system.combate.habilidades.habilidade5.nome}}"
                                    placeholder="+ nova habilidade"
                                />
                            </td>
                            <td class="is-val">
                                <input
                                    name="system.combate.habilidades.habilidade5.atual"
                                    type="number"
                                    value="{{system.combate.habilidades.habilidade5.atual}}"
                                />
